.claude-plugin/skills.old-*/
.codex-plugin/skills.tmp-*/
.codex-plugin/skills.old-*/
# BEE:END

# --- herdr-go project rules (outside bee-managed block) ---

# Rust build output.
/target/

# Frontend build + deps. static/ is the vite build output served by axum (regenerable).
/web/node_modules/
/web/dist/
/static/

*.sqlite
*.sqlite-*


# Agent skills = installed tooling, regenerable from their sources. Do not track
# the skill code itself; the distillery DATA under docs/distillery/ IS tracked.
.claude/skills/bee-*/
.agents/skills/bee-*/
.claude/skills/distill/

# Track the bee logs directory structure (.gitkeep) even though the BEE block
# ignores the dir, but never the log files themselves: they are rewritten on
# every bee tool call, so tracking them would dirty every checkout constantly
# and block `bee worktree merge` forever. The parent .bee/ is not excluded, so
# negating the dir itself re-includes its contents; re-ignore the *.jsonl logs.
!.bee/logs/
.bee/logs/*.jsonl

# Local secrets — NEVER commit (GitHub token for provisioning, web auth creds, web-push keys).
.env
*.local
*.local.env
secrets/

# DISTILL:START
/upstreams/
# DISTILL:END
