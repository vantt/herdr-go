# BEE:START
.bee/state.json
.bee/reservations.json
.bee/workers/
.bee/logs/
.bee/capture-queue.jsonl
.bee/feedback-digest.json
.bee/.inject-cache.json
.bee/HANDOFF.json
.bee/spikes/
.bee/manifest-hash.json
.bee/sessions/
.bee/claims/
.bee/runtime/
.bee/cache/
# BEE:END

# --- herdr-gateway project rules (outside bee-managed block) ---

# Rust build output.
/target/

# Frontend build + deps. static/ is the vite build output served by axum (regenerable).
/web/node_modules/
/web/dist/
/static/

# herdctl runtime state + local config (durable state is in the user's XDG dirs).
/herdctl.toml
*.sqlite
*.sqlite-*


# Agent skills = installed tooling, regenerable from their sources. Do not track
# the skill code itself; the distillery DATA under docs/distillery/ IS tracked.
.claude/skills/bee-*/
.agents/skills/bee-*/
.claude/skills/distill/

# Track bee logs (project intent) even though the BEE block ignores the dir.
# The parent .bee/ is not excluded, so negating the dir itself re-includes its contents.
!.bee/logs/

# Local secrets — NEVER commit (GitHub token for provisioning, web auth creds, web-push keys).
.env
*.local
*.local.env
secrets/

# DISTILL:START
/upstreams/
# DISTILL:END
