.bee/state.json
.bee/reservations.json
.bee/workers/
.bee/logs/
.bee/capture-queue.jsonl
.bee/feedback-digest.json
.bee/.inject-cache.json
.bee/HANDOFF.json
.bee/spikes/
.bee/manifest-hash.json
.bee/sessions/
.bee/claims/
.bee/runtime/
.bee/cache/
.bee/intent/
.bee/locks/
.bee/doctor-attest.json
.bee/native-transport-probe.json
.bee/config.local.json
.bee/tmp/
.bee/backups/
*.[0-9]*-*-*.tmp
